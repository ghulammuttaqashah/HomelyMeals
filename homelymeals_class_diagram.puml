@startuml

title HomelyMeals Class Diagram

skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontName "Arial"
skinparam defaultFontSize 12
skinparam linetype polyline
skinparam rectangle {
  BorderColor black
  FontColor black
  BackgroundColor white
}

' === Core Models ===

rectangle "Admin\n----\n- _id (ObjectId)\n- name\n- email\n- password\n- twoFactorEnabled\n- lastLogin\n----\n+ login()\n+ reviewComplaints()\n+ verifyCookDocuments()\n+ updateDeliveryCharges()" as Admin

rectangle "Customer\n----\n- _id (ObjectId)\n- name\n- email\n- contact\n- password\n- addresses[]\n- registrationDate\n- status\n- statusReason\n- warningsCount\n- createdAt\n- updatedAt\n----\n+ register()\n+ login()\n+ manageAddresses()\n+ placeOrder()" as Customer

rectangle "Cook\n----\n- _id (ObjectId)\n- name\n- email\n- contact\n- password\n- address\n- verificationStatus\n- serviceStatus\n- registrationDate\n- profilePicture\n- status\n- statusReason\n- maxDeliveryDistance\n- warningsCount\n- stripeAccountId\n- isOnlinePaymentEnabled\n- stripeAccountStatus\n- stripeOnboardingCompletedAt\n- createdAt\n- updatedAt\n----\n+ register()\n+ updateServiceStatus()\n+ manageMeals()\n+ processOrders()" as Cook

rectangle "CookDocument\n----\n- _id (ObjectId)\n- cookId (ObjectId, ref: Cook)\n- profilePicture\n- cnicFront\n- cnicBack\n- kitchenPhotos[]\n- sfaLicense\n- other\n- verifiedByAdmin (ObjectId, ref: Admin)\n- verifiedAt\n- createdAt\n- updatedAt\n----\n+ uploadDocument()\n+ resubmitDocument()\n+ checkVerificationStatus()" as CookDocument

rectangle "CookMeal\n----\n- _id (ObjectId)\n- cookId (ObjectId, ref: Cook)\n- name\n- description\n- price\n- category\n- availability\n- itemImage\n- createdAt\n- updatedAt\n----\n+ addMeal()\n+ updateMeal()\n+ changeAvailability()" as CookMeal

rectangle "Order\n----\n- _id (ObjectId)\n- orderNumber\n- customerId (ObjectId, ref: Customer)\n- cookId (ObjectId, ref: Cook)\n- items[]\n- subtotal\n- deliveryCharges\n- totalAmount\n- deliveryAddress\n- distance\n- estimatedTime\n- deliveryNote\n- paymentMethod\n- paymentStatus\n- paymentProof\n- paymentRejectionReason\n- paymentRejectionCount\n- paymentIntentId\n- stripeTransferId\n- paymentCompletedAt\n- status\n- rejectionReason\n- cancellationReason\n- cancelledBy\n- cancellationRequest\n- paymentDeadline\n- confirmedAt\n- preparingAt\n- outForDeliveryAt\n- estimatedDeliveryAt\n- deliveredAt\n- cancelledAt\n- createdAt\n- updatedAt\n----\n+ createOrder()\n+ updateStatus()\n+ handlePaymentState()" as Order

rectangle "Review\n----\n- _id (ObjectId)\n- customerId (ObjectId, ref: Customer)\n- cookId (ObjectId, ref: Cook)\n- orderId (ObjectId, ref: Order)\n- mealId (ObjectId, ref: CookMeal, optional)\n- rating\n- reviewText\n- reviewType\n- aspects[]\n- createdAt\n- updatedAt\n----\n+ submitReview()\n+ analyzeAspects()\n+ fetchByCookOrMeal()" as Review

rectangle "Chat\n----\n- _id (ObjectId)\n- customerId (ObjectId, ref: Customer)\n- cookId (ObjectId, ref: Cook)\n- messages[]\n- lastMessage\n- customerUnread\n- cookUnread\n- createdAt\n- updatedAt\n----\n+ sendMessage()\n+ markRead()\n+ getConversation()" as Chat

rectangle "Complaint\n----\n- _id (ObjectId)\n- orderId (ObjectId, ref: Order)\n- complainantType\n- complainantId (ObjectId, refPath: complainantTypeRef)\n- complainantTypeRef\n- againstUserId (ObjectId)\n- type\n- description\n- proofUrls[]\n- responses[]\n- status\n- adminResponse\n- createdAt\n- updatedAt\n----\n+ submitComplaint()\n+ addResponse()\n+ updateStatus()" as Complaint

rectangle "Warning\n----\n- _id (ObjectId)\n- userId (ObjectId, polymorphic via userType)\n- userType\n- complaintId (ObjectId, ref: Complaint)\n- message\n- createdAt\n----\n+ issueWarning()\n+ listWarningsByUser()" as Warning

rectangle "Plan\n----\n- _id (ObjectId)\n- name\n- price\n- duration\n- status\n- createdAt\n- updatedAt\n----\n+ createPlan()\n+ updatePlan()\n+ activateOrDeactivate()" as Plan

rectangle "Subscription\n----\n- _id (ObjectId)\n- cook_id (ObjectId, ref: Cook)\n- plan_id (ObjectId, ref: Plan)\n- start_date\n- end_date\n- status\n- stripe_payment_intent_id\n- createdAt\n- updatedAt\n----\n+ startSubscription()\n+ markExpired()\n+ updateStatus()" as Subscription

rectangle "DeliveryCharges\n----\n- _id (ObjectId)\n- pricePerKm\n- minimumCharge\n- maxDeliveryDistance\n- isActive\n- createdAt\n- updatedAt\n----\n+ getSettings()\n+ updateSettings()" as DeliveryCharges

rectangle "OTPVerification\n----\n- _id (ObjectId)\n- email\n- otpCode\n- purpose\n- expiryTime\n- isVerified\n- tempData\n- createdAt\n- updatedAt\n----\n+ generateOTP()\n+ verifyOTP()\n+ expireOTP()" as OTPVerification

' === Embedded Structures ===

rectangle "Address (Embedded)\n----\n- label\n- houseNo\n- street\n- city\n- postalCode\n- latitude\n- longitude\n- isDefault\n- location" as Address

rectangle "Location (Embedded)\n----\n- latitude\n- longitude" as Location

rectangle "Message (Embedded)\n----\n- senderId (ObjectId, refPath: senderType)\n- senderType\n- content\n- read\n- readAt\n- createdAt\n- updatedAt" as Message

rectangle "LastMessage (Embedded)\n----\n- content\n- senderId (ObjectId)\n- senderType\n- createdAt" as LastMessage

rectangle "Proof (Embedded)\n----\n- url\n- uploadedAt" as Proof

rectangle "DocumentFile (Embedded)\n----\n- url\n- status\n- uploadedAt\n- rejectedReason" as DocumentFile

rectangle "ComplaintResponse (Embedded)\n----\n- senderId (ObjectId)\n- senderRole\n- senderName\n- text\n- proofUrls[]\n- createdAt" as ComplaintResponse

rectangle "OrderItem (Embedded)\n----\n- mealId (ObjectId, ref: Meal)\n- name\n- price\n- quantity\n- itemImage" as OrderItem

rectangle "DeliveryAddress (Embedded)\n----\n- label\n- houseNo\n- street\n- city\n- postalCode\n- latitude\n- longitude" as DeliveryAddress

rectangle "CancellationRequest (Embedded)\n----\n- status\n- reason\n- requestedAt\n- respondedAt\n- cookResponse" as CancellationRequest

rectangle "TempData (Embedded)\n----\n- name\n- contact\n- password\n- address" as TempData

rectangle "TempAddress (Embedded)\n----\n- houseNo\n- street\n- city\n- postalCode" as TempAddress

rectangle "ReviewAspect (Embedded)\n----\n- aspect\n- sentiment\n- keywords[]\n- reason" as ReviewAspect

' === Core Relationships (schema refs first) ===

Customer "1" --> "0..*" Order : places
Cook "1" --> "0..*" Order : receives

Cook "1" --> "0..*" CookMeal : owns
Cook "1" --> "0..*" CookDocument : has documents
Admin "1" --> "0..*" CookDocument : verifies

Customer "1" --> "0..*" Review : writes
Cook "1" --> "0..*" Review : receives
Order "1" --> "0..*" Review : reviewed in
CookMeal "1" --> "0..*" Review : meal review

Customer "1" --> "0..*" Chat : participates
Cook "1" --> "0..*" Chat : participates

Order "1" --> "0..*" Complaint : can be disputed
Customer "1" --> "0..*" Complaint : complainant via refPath
Cook "1" --> "0..*" Complaint : complainant via refPath

Complaint "1" --> "0..*" Warning : complaintId

Cook "1" --> "0..*" Subscription : subscribes
Plan "1" --> "0..*" Subscription : selected plan

Order "1" --> "1..*" OrderItem : includes
OrderItem "0..*" ..> "0..*" CookMeal : mealId ref is Meal (legacy naming)

' === Inferred / business-flow relationships (dashed) ===

DeliveryCharges "1" ..> "0..*" Order : pricing policy applies
Customer "1" ..> "0..*" OTPVerification : verification flow
Cook "1" ..> "0..*" OTPVerification : verification flow
Admin "1" ..> "0..*" OTPVerification : verification flow
Customer "1" ..> "0..*" Warning : userType=customer path
Cook "1" ..> "0..*" Warning : userType=cook path

' === Embedded Relationships ===

Customer "1" *-- "0..*" Address : addresses
Cook "1" *-- "1" Address : address
Address "1" *-- "0..1" Location : location

Chat "1" *-- "0..*" Message : messages
Chat "1" *-- "0..1" LastMessage : lastMessage

Complaint "1" *-- "0..*" Proof : proofUrls
Complaint "1" *-- "0..*" ComplaintResponse : responses
ComplaintResponse "1" *-- "0..*" Proof : proofUrls

CookDocument "1" *-- "0..1" DocumentFile : profilePicture
CookDocument "1" *-- "0..1" DocumentFile : cnicFront
CookDocument "1" *-- "0..1" DocumentFile : cnicBack
CookDocument "1" *-- "0..*" DocumentFile : kitchenPhotos
CookDocument "1" *-- "0..1" DocumentFile : sfaLicense
CookDocument "1" *-- "0..1" DocumentFile : other

Order "1" *-- "1" DeliveryAddress : deliveryAddress
Order "1" *-- "0..1" CancellationRequest : cancellationRequest

OTPVerification "1" *-- "0..1" TempData : tempData
TempData "1" *-- "0..1" TempAddress : address

Review "1" *-- "0..*" ReviewAspect : aspects

note bottom of OTPVerification
No direct schema ObjectId ref to Customer, Cook, or Admin.
Links above are process-level, not explicit ref fields.
end note

note bottom of OrderItem
Schema uses ref: Meal in OrderItem.mealId.
Review uses ref: CookMeal for mealId.
end note

@enduml
