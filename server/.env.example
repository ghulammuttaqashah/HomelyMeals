# ============================================
# HOMELYMEALS SERVER ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000

# MongoDB Connection
# Local: mongodb://localhost:27017/homelymeals
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/homelymeals
MONGO_URI=mongodb://localhost:27017/homelymeals

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Email Configuration (Gmail SMTP)
# Get app password: https://myaccount.google.com/apppasswords
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_character_app_password

# Stripe Configuration
# Get keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Groq API Key (for AI Chatbot and ABSA)
# Get free key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenRoute API Key (for distance calculation)
# Get free key from: https://openrouteservice.org/dev/#/signup
OPENROUTE_API_KEY=your_openroute_api_key_here

# Frontend URLs (Development)
CUSTOMER_APP_URL=http://localhost:5173
COOK_APP_URL=http://localhost:5174
ADMIN_APP_URL=http://localhost:5175

# ============================================
# SETUP INSTRUCTIONS
# ============================================
# 1. Install MongoDB locally or use MongoDB Atlas
# 2. Create a Groq account and get API key (required for chatbot)
# 3. Create a Stripe account and get test keys (required for payments)
# 4. Create Gmail app password (required for OTP emails)
# 5. Get OpenRoute API key (optional, for accurate distance)
# 6. Copy this file to .env and fill in your values
# 7. Run: npm install
# 8. Run: npm run dev
